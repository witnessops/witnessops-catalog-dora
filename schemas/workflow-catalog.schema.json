{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/witnessops/witnessops-catalog-dora/schemas/workflow-catalog.schema.json",
  "title": "WitnessOps DORA Workflow Catalog",
  "$defs": {
    "ownerEnum": {
      "type": "string",
      "enum": [
        "architecture_owner",
        "backup_owner",
        "compliance_reporting_owner",
        "control_owner",
        "incident_manager",
        "incident_review_chair",
        "legal_risk_authority",
        "notification_authority",
        "platform_owner",
        "policy_owner",
        "recovery_owner",
        "regulatory_liaison_authority",
        "regulatory_reporting_authority",
        "resilience_risk_authority",
        "risk_owner",
        "senior_testing_authority",
        "service_owner",
        "testing_authority",
        "third_party_risk_authority",
        "vendor_risk_owner"
      ]
    }
  },
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "workflow_id",
      "workflow_name",
      "trigger",
      "owner",
      "deadline",
      "required_evidence",
      "status_states",
      "dora_mapping"
    ],
    "properties": {
      "workflow_id": {
        "type": "string",
        "pattern": "^DORA-[0-9]{3}$"
      },
      "workflow_name": {
        "type": "string",
        "minLength": 1
      },
      "trigger": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "owner": {
        "$ref": "#/$defs/ownerEnum"
      },
      "deadline": {
        "anyOf": [
          {
            "type": "null"
          },
          {
            "$ref": "https://github.com/witnessops/witnessops-catalog-dora/schemas/deadline.schema.json"
          }
        ]
      },
      "required_evidence": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "status_states": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "dora_mapping": {
        "$ref": "https://github.com/witnessops/witnessops-catalog-dora/schemas/dora-mapping.schema.json"
      }
    }
  }
}
