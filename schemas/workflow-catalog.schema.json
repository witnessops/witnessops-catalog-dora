{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/witnessops/witnessops-catalog-dora/schemas/workflow-catalog.schema.json",
  "title": "WitnessOps DORA Workflow Catalog",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "workflow_id",
      "workflow_name",
      "trigger",
      "owner",
      "deadline",
      "required_evidence",
      "status_states",
      "dora_mapping"
    ],
    "properties": {
      "workflow_id": {
        "type": "string",
        "pattern": "^DORA-[0-9]{3}$"
      },
      "workflow_name": {
        "type": "string",
        "minLength": 1
      },
      "trigger": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "owner": {
        "type": "string",
        "minLength": 1
      },
      "deadline": {
        "anyOf": [
          {
            "type": "null"
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "required_evidence": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "status_states": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "dora_mapping": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pillars", "official_surface"],
        "properties": {
          "pillars": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "official_surface": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
