{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/witnessops/witnessops-catalog-dora/schemas/workflow-catalog.schema.json",
  "title": "WitnessOps DORA Workflow Catalog",
  "$defs": {
    "ownerEnum": {
      "type": "string",
      "enum": [
        "architecture_owner",
        "backup_owner",
        "compliance_reporting_owner",
        "control_owner",
        "incident_manager",
        "incident_review_chair",
        "legal_risk_authority",
        "notification_authority",
        "platform_owner",
        "policy_owner",
        "recovery_owner",
        "regulatory_liaison_authority",
        "regulatory_reporting_authority",
        "resilience_risk_authority",
        "risk_owner",
        "senior_testing_authority",
        "service_owner",
        "testing_authority",
        "third_party_risk_authority",
        "vendor_risk_owner"
      ]
    },
    "deadlineTypeEnum": {
      "type": "string",
      "enum": [
        "contractual_notice_window",
        "external_request_deadline",
        "governance_reporting_cycle",
        "immediate_intake",
        "internal_gate",
        "internal_policy",
        "internal_policy_or_competent_authority_guidance",
        "periodic_review",
        "pre_contract_gate",
        "pre_participation_gate",
        "program_cycle",
        "regulatory_multi_stage",
        "regulatory_record_maintenance",
        "risk_based_review_cycle",
        "severity_based_internal_sla"
      ]
    },
    "doraPillarEnum": {
      "type": "string",
      "enum": [
        "digital_operational_resilience_testing",
        "ict_related_incidents",
        "ict_risk_management",
        "ict_third_party_risk_management",
        "information_sharing"
      ]
    }
  },
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "workflow_id",
      "workflow_name",
      "trigger",
      "owner",
      "deadline",
      "required_evidence",
      "status_states",
      "dora_mapping"
    ],
    "properties": {
      "workflow_id": {
        "type": "string",
        "pattern": "^DORA-[0-9]{3}$"
      },
      "workflow_name": {
        "type": "string",
        "minLength": 1
      },
      "trigger": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "owner": {
        "$ref": "#/$defs/ownerEnum"
      },
      "deadline": {
        "anyOf": [
          {
            "type": "null"
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "$ref": "#/$defs/deadlineTypeEnum"
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "required_evidence": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "status_states": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "dora_mapping": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pillars", "official_surface"],
        "properties": {
          "pillars": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/doraPillarEnum"
            }
          },
          "official_surface": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
