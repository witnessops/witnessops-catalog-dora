    "intermediate_report_packet",
    "final_report_packet",
    "submission_receipts",
    "incident_lineage",
    "approver_identity"
  ],
  "status_states": [
    "awaiting_initial_report",
    "initial_report_submitted",
    "awaiting_intermediate_report",
    "intermediate_report_submitted",
    "awaiting_final_report",
    "final_report_submitted",
    "closed",
    "overdue"
  ],
  "dora_mapping": {
    "pillars": [
      "ict_related_incidents"
    ],
    "official_surface": [
      "major_incident_reporting"
